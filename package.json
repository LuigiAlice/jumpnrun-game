{
  "name": "jumpnrun-game",
  "version": "1.0.0",
  "description": "2D Jump & Run Spiel mit Phaser 3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "tsc --noEmit && vitest run",
